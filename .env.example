# Copy this file to `.env` and fill in your real values.
# `.env` is gitignored — it never gets committed to GitHub.

# --- Samsara API credentials ---
# Generate in Samsara dashboard: Settings → API Tokens → Add API Token
# Scope needed: Full Access (or at minimum: Fleet Read + Safety Read)
SAMSARA_API_TOKEN=your_samsara_api_token_here

# --- Samsara alert recipients ---
# Comma-separated list of emails to notify when fault codes or DVIR defects are found
ALERT_FROM_UPN=jeff@xfreight.net
ALERT_TO_EMAILS=jeff@xfreight.net,maintenance@xfreight.net

# --- Alvys API credentials ---
# Get these from Alvys: Settings → API/Integrations
ALVYS_CLIENT_ID=your_client_id_here
ALVYS_CLIENT_SECRET=your_client_secret_here

# --- Date range ---
# How far back to pull data. Format: YYYY-MM-DD
# Tip: first run, use a wide range (e.g. 2024-01-01) to backfill history.
# After that, you can keep it wide — Alvys handles the volume fine.
ALVYS_START_DATE=2024-01-01

# --- Output location ---
# Where the resulting Alvys_Master.xlsx gets written.
# Leave as "output" for Phase 1 local testing.
OUTPUT_DIR=output

# =============================================================================
# Microsoft Graph / OneDrive — shared by ALL uploads + Samsara alerts
# =============================================================================
# One Azure (Entra) app registration, client-credentials flow.
# Needs Application permissions (admin-consented):
#   Files.ReadWrite.All  (uploads)   +   Mail.Send  (Samsara alerts)
AZURE_TENANT_ID=your_tenant_guid_here
AZURE_CLIENT_ID=your_app_registration_guid_here
AZURE_CLIENT_SECRET=your_app_secret_value_here

# Whose OneDrive the files are written to (app-only auth targets a user by UPN).
ONEDRIVE_USER_UPN=jeff@xfreight.net

# Alvys upload only: destination folder ("" = OneDrive root) and filename.
# The CI workflow uploads the pipeline's computed output as "Alvys Pipeline.xlsx".
# Do NOT use "Alvys Master 2026.xlsx" here — that is the hand-maintained workbook
# the Power BI report reads, and the upload replaces by name, so it would clobber
# the manual file.
ONEDRIVE_FOLDER_PATH=
ONEDRIVE_TARGET_FILENAME=Alvys Pipeline.xlsx

# =============================================================================
# QuickBooks Online — 5 companies (realms)
# =============================================================================
# Intuit production app credentials (Intuit Developer → your app → Keys).
QB_CLIENT_ID=your_intuit_client_id_here
QB_CLIENT_SECRET=your_intuit_client_secret_here

# Per-company refresh tokens. NOTE: QuickBooks rotates the refresh token on
# every run; the GitHub Actions job writes the new value back to Secrets via
# `gh secret set`. When testing locally you may advance these out from under CI.
QB_XTRUX_REFRESH_TOKEN=your_xtrux_refresh_token_here
QB_TRUKWAY_REFRESH_TOKEN=your_trukway_refresh_token_here
QB_XLINX_REFRESH_TOKEN=your_xlinx_refresh_token_here

# N&J pair — fill in once API access is granted (realm IDs are not secret).
QB_NJ_TRAILERS_REALM_ID=
QB_NJ_TRAILERS_REFRESH_TOKEN=
QB_NJ_PROPERTIES_REALM_ID=
QB_NJ_PROPERTIES_REFRESH_TOKEN=

# Output dir for the QB_*.xlsx files.
QB_OUTPUT_DIR=output/quickbooks

# Optional: Samsara look-back window (days) for trips/safety/DVIRs. Default 90.
SAMSARA_DAYS_BACK=90
SAMSARA_OUTPUT_DIR=output/samsara
